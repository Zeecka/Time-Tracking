# Database Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=record_db
MYSQL_USER=record_user
MYSQL_PASSWORD=record_password

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production
CORS_ORIGINS=http://localhost:3000

# Stats Configuration
# Comma-separated list of tracking codes treated as absence in statistics.
# Example: ABS. Projects linked to these codes are treated as absence time.
STATS_EXCLUDE_CODES=

# OIDC / OAuth2 Configuration (optional)
# Set OIDC_ISSUER on the backend to enable JWT authentication for all API routes.
# Leave empty to run without authentication (default).
# Example: https://accounts.google.com  or  https://keycloak.example.com/realms/myrealm
OIDC_ISSUER=
# Optional: restrict accepted tokens to a specific audience (client_id).
OIDC_AUDIENCE=

# Frontend Configuration
REACT_APP_API_URL=http://localhost:5000/api/v1

# Frontend OIDC / OAuth2 Configuration (optional)
# Set both variables to enable OIDC login in the browser.
# REACT_APP_OIDC_AUTHORITY must match the backend OIDC_ISSUER value.
REACT_APP_OIDC_AUTHORITY=
REACT_APP_OIDC_CLIENT_ID=
# Optional: override the redirect URI after login (defaults to the app's origin).
REACT_APP_OIDC_REDIRECT_URI=
# Optional: override the requested OIDC scopes (default: openid profile email).
REACT_APP_OIDC_SCOPE=

# JS Code Export
# Optional override of the default textarea template on the Export page.
# Write a JS function body (inputs: timeEntries, activeColumns, filters, t) that returns a JS string.
# If not set, the built-in default template is used.
REACT_APP_EXPORT_JS_TEMPLATE=
